{
  "_description": "Complex Enterprise Sales Analytics - Multi-Domain Insurance/Finance Pipeline",
  "_use_case": "21 source tables across insurance, finance, marketing, claims - joins to single target",
  "_target": "bd_work.pps_jss_test",

  "job_name": "complex_enterprise_sales",
  "job_description": "Enterprise sales analytics joining 21 source tables across insurance, finance, marketing, claims domains",

  "script": {
    "path": "s3://etl-framework-scripts/pyspark/complex_enterprise_sales.py",
    "local_path": "scripts/pyspark/complex_enterprise_sales.py",
    "type": "pyspark"
  },

  "job_arguments": {
    "--source_database": "multiple",
    "--target_database": "bd_work",
    "--target_table": "pps_jss_test",
    "--run_mode": "full",
    "--partition_date": "{{ ds }}"
  },

  "platform": {
    "primary": "glue",
    "fallback_chain": ["emr", "eks"],
    "force_platform": null,
    "auto_fallback_on_error": "Y",
    "_comment": "Full fallback chain: Glue → EMR → EKS with Karpenter",

    "auto_convert": {
      "enabled": "Y",
      "convert_to_emr_threshold_gb": 100,
      "convert_to_eks_threshold_gb": 500,
      "optimize_for": "cost",
      "_comment": "Auto-convert to EMR when data > 100GB, EKS when > 500GB"
    }
  },

  "smart_allocation": {
    "enabled": "Y",
    "auto_apply": "Y",
    "consider_weekday_weekend": "Y",
    "consider_month_end": "Y",
    "consider_data_trends": "Y",
    "weekend_scale_factor": 0.6,
    "month_end_scale_factor": 1.5,
    "quarter_end_scale_factor": 2.0,
    "_comment": "Weekend runs are lighter due to no business activity"
  },

  "source_sizing": {
    "mode": "hybrid",
    "_modes": "auto_detect | hardcoded | hybrid (use hardcoded if provided, else auto-detect)",
    "delta_mode": {
      "enabled": "Y",
      "detect_partition_size": "Y",
      "partition_column": "process_date",
      "_comment": "For delta runs, only count today's partition size"
    },
    "cache_sizes": "Y",
    "cache_ttl_hours": 24,
    "size_cache_path": "data/agent_store/source_sizes.json"
  },

  "glue_config": {
    "glue_version": "4.0",
    "worker_type": "G.2X",
    "number_of_workers": 20,
    "timeout_minutes": 360,
    "max_retries": 2,
    "_comment": "These values may be overridden by smart_allocation if enabled",
    "spark_configs": {
      "spark.sql.adaptive.enabled": "true",
      "spark.sql.adaptive.coalescePartitions.enabled": "true",
      "spark.sql.adaptive.skewJoin.enabled": "true",
      "spark.sql.shuffle.partitions": "400",
      "spark.sql.broadcastTimeout": "600",
      "spark.dynamicAllocation.enabled": "true"
    }
  },

  "emr_config": {
    "release_label": "emr-6.15.0",
    "instance_type": "m5.2xlarge",
    "instance_count": 10,
    "use_spot": "Y",
    "spot_bid_percentage": 80,
    "applications": ["Spark", "Hadoop"],
    "spark_configs": {
      "spark.executor.memory": "12g",
      "spark.executor.cores": "4",
      "spark.sql.shuffle.partitions": "400",
      "spark.dynamicAllocation.enabled": "true"
    }
  },

  "eks_config": {
    "cluster_name": "enterprise-etl-eks",
    "namespace": "spark-jobs",
    "use_karpenter": "Y",
    "use_spot": "Y",
    "use_graviton": "Y",
    "executor_instances": 20,
    "executor_memory": "12g",
    "executor_cores": 4
  },

  "auto_healing": {
    "enabled": "Y",
    "correct_code": "Y",
    "auto_rerun": "Y",
    "max_retries": 3,
    "heal_memory_errors": "Y",
    "heal_shuffle_errors": "Y",
    "heal_timeout_errors": "Y",
    "heal_connection_errors": "Y",
    "heal_data_skew": "Y",
    "heal_partition_errors": "Y",
    "_comment": "Full auto-healing for complex multi-join pipeline"
  },

  "code_analysis": {
    "enabled": "Y",
    "check_anti_patterns": "Y",
    "check_join_optimizations": "Y",
    "check_window_functions": "Y",
    "check_aggregation_patterns": "Y",
    "recommend_aws_tools": "Y",
    "recommend_broadcast_joins": "Y",
    "recommend_caching": "Y"
  },

  "data_quality": {
    "enabled": "Y",
    "fail_on_critical": "Y",
    "sample_size": 100000,

    "natural_language_rules": [
      "customer_id should not be null",
      "policy_number should not be null",
      "effective_date should not be null",
      "premium_amount should be positive when present",
      "claim_amount should be positive when present",
      "membership_id should not be null"
    ],

    "sql_rules": [
      {
        "id": "SQL_CUSTOMER_EXISTS",
        "description": "Every record must have a valid customer",
        "sql": "SELECT COUNT(*) FROM bd_work.pps_jss_test WHERE customer_id IS NULL",
        "threshold": 0,
        "severity": "critical"
      },
      {
        "id": "SQL_POLICY_VALID",
        "description": "Policy numbers should be valid format",
        "sql": "SELECT COUNT(*) FROM bd_work.pps_jss_test WHERE policy_number IS NOT NULL AND LENGTH(policy_number) < 5",
        "threshold": 100,
        "severity": "warning"
      },
      {
        "id": "SQL_DATE_RANGE",
        "description": "Dates should be within valid range",
        "sql": "SELECT COUNT(*) FROM bd_work.pps_jss_test WHERE effective_date < '2000-01-01' OR effective_date > CURRENT_DATE",
        "threshold": 0,
        "severity": "error"
      }
    ],

    "template_rules": [
      {
        "template": "null_check",
        "parameters": {"column": "customer_id"}
      },
      {
        "template": "completeness_check",
        "parameters": {"column": "policy_number"},
        "threshold": 0.99
      },
      {
        "template": "row_count_check",
        "parameters": {"min_rows": 10000, "max_rows": 500000000}
      }
    ]
  },

  "compliance": {
    "enabled": "Y",
    "check_sources": "Y",
    "check_targets": "Y",
    "frameworks": ["GDPR", "PCI_DSS", "SOX", "HIPAA"],
    "pii_columns": [
      "customer_name", "customer_email", "phone", "address",
      "ssn", "driver_license", "date_of_birth", "credit_card_number"
    ],
    "mask_pii": "Y",
    "mask_strategy": "hash",
    "audit_data_access": "Y",
    "retention_days": 365,
    "_comment": "Full compliance for insurance/finance data"
  },

  "workload_assessment": {
    "enabled": "Y",
    "analyze_input_size": "Y",
    "consider_weekday_weekend": "Y",
    "use_historical_trends": "Y",
    "monitor_cpu_load": "Y",
    "monitor_memory_profile": "Y",
    "monitor_executor_usage": "Y",
    "detect_data_skew": "Y",
    "track_s3_bytes": "Y",
    "track_shuffle_bytes": "Y",
    "track_cost": "Y",
    "recommend_resources": "Y"
  },

  "learning": {
    "enabled": "Y",
    "store_history": "Y",
    "history_table": "etl_execution_history",
    "baseline_table": "etl_job_baselines",
    "detect_anomalies": "Y",
    "predict_failures": "Y",
    "update_baseline": "Y",
    "trend_window_days": 30
  },

  "recommendation": {
    "enabled": "Y",
    "aggregate_from_all_agents": "Y",
    "prioritize_by_impact": "Y",
    "generate_implementation_plan": "Y",
    "track_recommendation_status": "Y"
  },

  "integrations": {
    "slack_enabled": "Y",
    "slack_channel": "#enterprise-etl-alerts",
    "slack_voice_enabled": "Y",
    "slack_etl_trigger_enabled": "Y",
    "slack_notifications": {
      "on_start": "Y",
      "on_success": "Y",
      "on_failure": "Y",
      "on_dq_failure": "Y",
      "on_healing": "Y",
      "include_metrics": "Y",
      "include_recommendations": "Y"
    },

    "teams_enabled": "Y",
    "teams_webhook_url": "https://outlook.office.com/webhook/...",
    "teams_notifications": {
      "on_start": "N",
      "on_success": "Y",
      "on_failure": "Y"
    },

    "email_enabled": "Y",
    "email_sender": "etl-notifications@company.com",
    "email_recipients": [
      "data-engineering@company.com",
      "insurance-analytics@company.com"
    ],
    "email_on_success": "Y",
    "email_on_failure": "Y",
    "email_daily_summary": "Y"
  },

  "dashboard": {
    "cloudwatch_enabled": "Y",
    "cloudwatch_namespace": "ETL/EnterpriseSales",
    "cloudwatch_metrics": [
      "duration_seconds",
      "records_processed",
      "cost_dollars",
      "dq_pass_rate",
      "memory_utilization",
      "cpu_utilization"
    ],
    "cloudwatch_alarms": {
      "duration_threshold_minutes": 240,
      "cost_threshold_dollars": 200,
      "dq_failure_threshold": 0.95
    }
  },

  "audit": {
    "enabled": "Y",
    "dynamo_table": "etl_audit_log",
    "audit_on_start": "Y",
    "audit_on_read": "Y",
    "audit_on_transform": "Y",
    "audit_on_dq": "Y",
    "audit_on_compliance": "Y",
    "audit_on_write": "Y",
    "audit_on_complete": "Y",
    "audit_on_error": "Y",
    "audit_on_healing": "Y",
    "include_row_counts": "Y",
    "include_schema_info": "Y"
  },

  "source_tables": [
    {
      "_domain": "FINANCE",
      "database": "finance_accounting_master",
      "table": "autopay_products_master",
      "format": "parquet",
      "location": "s3://enterprise-data/finance_accounting_master/autopay_products_master/",
      "estimated_size_gb": 0.5,
      "broadcast": true,
      "auto_detect_size": "Y"
    },
    {
      "database": "financial_services_datalake",
      "table": "batch_prescreen_output",
      "format": "parquet",
      "location": "s3://enterprise-data/financial_services_datalake/batch_prescreen_output/",
      "estimated_size_gb": 25,
      "partition_column": "process_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "DIGITAL/CLICKSTREAM",
      "database": "digital_master",
      "table": "clickstream_hits_master",
      "format": "parquet",
      "location": "s3://enterprise-data/digital_master/clickstream_hits_master/",
      "estimated_size_gb": 500,
      "partition_column": "hit_date",
      "_note": "Very large - may trigger EMR/EKS conversion",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "CUSTOMER",
      "database": "customer_master",
      "table": "customer_product_profile_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/customer_master/customer_product_profile_history_master/",
      "estimated_size_gb": 80,
      "partition_column": "snapshot_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "customer_staging",
      "table": "cpm_drv_tbl",
      "format": "parquet",
      "location": "s3://enterprise-data/customer_staging/cpm_drv_tbl/",
      "estimated_size_gb": 15,
      "auto_detect_size": "Y"
    },
    {
      "database": "customer_staging",
      "table": "disaster_zipcodes",
      "format": "parquet",
      "location": "s3://enterprise-data/customer_staging/disaster_zipcodes/",
      "estimated_size_gb": 0.01,
      "broadcast": true
    },

    {
      "_domain": "DISCOUNTS",
      "database": "discounts_master",
      "table": "discounts_transactions",
      "format": "parquet",
      "location": "s3://enterprise-data/discounts_master/discounts_transactions/",
      "estimated_size_gb": 30,
      "partition_column": "transaction_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "MARKETING",
      "database": "marketing_master",
      "table": "email_transactions",
      "format": "parquet",
      "location": "s3://enterprise-data/marketing_master/email_transactions/",
      "estimated_size_gb": 45,
      "partition_column": "send_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "marketing_master",
      "table": "marketing_product_profile_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/marketing_master/marketing_product_profile_history_master/",
      "estimated_size_gb": 60,
      "partition_column": "snapshot_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "CLAIMS",
      "database": "claims_master",
      "table": "enterprise_claims_master",
      "format": "parquet",
      "location": "s3://enterprise-data/claims_master/enterprise_claims_master/",
      "estimated_size_gb": 120,
      "partition_column": "claim_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "GIS/REFERENCE",
      "database": "ace_common",
      "table": "gis_lodge_name_assigned_zips",
      "format": "parquet",
      "location": "s3://enterprise-data/ace_common/gis_lodge_name_assigned_zips/",
      "estimated_size_gb": 0.05,
      "broadcast": true
    },
    {
      "database": "ace_common",
      "table": "gis_national_zip_codes",
      "format": "parquet",
      "location": "s3://enterprise-data/ace_common/gis_national_zip_codes/",
      "estimated_size_gb": 0.1,
      "broadcast": true
    },

    {
      "_domain": "INSURANCE - AUTO",
      "database": "insurance_master",
      "table": "auto_policy_driver_master",
      "format": "parquet",
      "location": "s3://enterprise-data/insurance_master/auto_policy_driver_master/",
      "estimated_size_gb": 75,
      "partition_column": "effective_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "insurance_master",
      "table": "auto_policy_vehicle_master",
      "format": "parquet",
      "location": "s3://enterprise-data/insurance_master/auto_policy_vehicle_master/",
      "estimated_size_gb": 65,
      "partition_column": "effective_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "insurance_master",
      "table": "policy_term_master",
      "format": "parquet",
      "location": "s3://enterprise-data/insurance_master/policy_term_master/",
      "estimated_size_gb": 20,
      "broadcast": true,
      "auto_detect_size": "Y"
    },

    {
      "_domain": "INSURANCE - HOME",
      "database": "insurance_master",
      "table": "home_policy_property_master",
      "format": "parquet",
      "location": "s3://enterprise-data/insurance_master/home_policy_property_master/",
      "estimated_size_gb": 55,
      "partition_column": "effective_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "LIFE INSURANCE",
      "database": "life_insurance_master",
      "table": "life_party_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/life_insurance_master/life_party_history_master/",
      "estimated_size_gb": 40,
      "partition_column": "snapshot_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "life_insurance_master",
      "table": "life_policy_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/life_insurance_master/life_policy_history_master/",
      "estimated_size_gb": 35,
      "partition_column": "snapshot_date",
      "auto_detect_size": "Y"
    },
    {
      "database": "life_insurance_master",
      "table": "policy_transaction_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/life_insurance_master/policy_transaction_history_master/",
      "estimated_size_gb": 50,
      "partition_column": "transaction_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "CRM",
      "database": "crm_master",
      "table": "lead_history_master",
      "format": "parquet",
      "location": "s3://enterprise-data/crm_master/lead_history_master/",
      "estimated_size_gb": 25,
      "partition_column": "lead_date",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "MEMBERSHIP",
      "database": "membership_master",
      "table": "membership_sales_master",
      "format": "parquet",
      "location": "s3://enterprise-data/membership_master/membership_sales_master/",
      "estimated_size_gb": 30,
      "partition_column": "sale_date",
      "auto_detect_size": "Y"
    }
  ],

  "target_tables": [
    {
      "database": "bd_work",
      "table": "pps_jss_test",
      "format": "parquet",
      "location": "s3://enterprise-data/bd_work/pps_jss_test/",
      "partition_by": ["process_year", "process_month"],
      "write_mode": "overwrite_partitions",
      "enable_statistics": true
    }
  ],

  "schedule": {
    "enabled": "Y",
    "cron_expression": "0 5 * * *",
    "timezone": "America/New_York",
    "retry_on_failure": "Y",
    "max_retries": 2,
    "_comment": "Runs at 5 AM ET daily"
  }
}
