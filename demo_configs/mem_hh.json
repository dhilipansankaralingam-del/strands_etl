{
  "_description": "HouseHold Members base Pipeline",
  "_framework": "Strands SDK Multi-Agent ETL Framework",
  "_use_case": "3 source tables Household membersbase in Membership_base Agents - joins to single target",
  "_target": "membership_base.household_members_base",

  "job_name": "ace-da-membership-base-household-members",
  "job_description": "2 source tables Member Info, Membership Household Datalake tables - joins to single target Membership_base.household_members_base",

  "script": {
    "path": "s3://aws-glue-assets-564021763094-us-west-2/scripts/ace-da-membership-base-household-members.py",
    "local_path": "scripts/pyspark/ace-da-membership-base-household-members.py",
    "type": "pyspark"
  },

  "job_arguments": {
    "--source_database": "multiple",
    "--target_database": "membership_base",
    "--target_table": "household_members_base",
    "--run_mode": "delta",
    "--partition_date": "{{ ds }}"
  },

  "platform": {
    "primary": "glue",
    "fallback_chain": ["emr", "eks"],
    "force_platform": null,
    "auto_fallback_on_error": "N",
    "_comment": "Full fallback chain: Glue → EMR → EKS with Karpenter",

    "auto_convert": {
      "enabled": "N",
      "convert_to_emr_threshold_gb": 10,
      "convert_to_eks_threshold_gb": 50,
      "optimize_for": "cost",
      "_comment": "Auto-convert to EMR when data > 100GB, EKS when > 500GB"
    },

    "code_conversion": {
      "enabled": "N",
      "convert_pyspark_code": "Y",
      "preserve_original": "Y",
      "output_converted_script_path": "converted/",
      "_comment": "Convert GlueContext/DynamicFrame code to SparkSession/DataFrame for target platform"
    }
  },

  "smart_allocation": {
    "enabled": "Y",
    "force_from_config": "N",
    "_force_comment": "Y = use glue_config workers/type exactly (user-forced). N = agent decides based on data size, complexity, day-type",
    "auto_apply": "Y",
    "consider_weekday_weekend": "Y",
    "consider_month_end": "Y",
    "consider_data_trends": "Y",
    "consider_complexity": "Y",
    "complexity_factors": {
      "join_count_weight": 1.5,
      "window_function_weight": 2.0,
      "aggregation_weight": 1.2,
      "distinct_weight": 1.3,
      "_comment": "Multipliers applied per complexity factor found in script"
    },
    "weekend_scale_factor": 0.6,
    "month_end_scale_factor": 1.5,
    "quarter_end_scale_factor": 2.0,
    "_comment": "Weekend runs are lighter due to no business activity"
  },

  "source_sizing": {
    "mode": "auto_detect",
    "_modes": "auto_detect | hardcoded | hybrid",
    "_detection_order": [
      "1. Glue Catalog sizeInBytes parameter (MSCK REPAIR TABLE or Glue Crawlers)",
      "2. S3 list_objects_v2 scan (if Glue Catalog unavailable)",
      "3. estimated_size_gb from config (fallback)",
      "4. Smart estimate based on table type (last resort)"
    ],
    "delta_mode": {
      "enabled": "Y",
      "detect_partition_size": "Y",
      "partition_column": "process_date",
      "_comment": "For delta runs, only count today's partition size"
    },
    "cache_sizes": "N",
    "cache_ttl_hours": 24,
    "size_cache_path": "data/agent_store/source_sizes_enterprise_life_policy_master.json"
  },

  "storage": {
    "_comment": "Fallback storage configuration - uses local pipe-delimited files if DynamoDB/S3 unavailable",
    "primary_backend": "local",
    "fallback_backend": "local",
    "dynamo_table_prefix": "etl_",
    "dynamo_region": "us-west-2",
    "s3_bucket": "enterprise-etl-data",
    "s3_prefix": "etl-data/",
    "local_base_path": "data/agent_store",
    "local_format": "pipe",
    "_storage_types": {
      "audit_logs": "Pipe-delimited files in data/agent_store/audit_logs/",
      "agent_data": "Pipe-delimited files per agent in data/agent_store/{agent_name}/",
      "learning_history": "Local JSON files in data/agent_store/learning_agent/",
      "recommendations": "Pipe-delimited files in data/agent_store/recommendation_agent/"
    }
  },

  "agents": {
    "_comment": "Strands SDK multi-agent configuration",
    "parallel_execution": "Y",
    "max_workers": 10,
    "fail_fast": "N",

    "sizing_agent": {
      "enabled": "Y",
      "phase": 1,
      "dependencies": []
    },
    "compliance_agent": {
      "enabled": "Y",
      "phase": 1,
      "dependencies": []
    },
    "code_analysis_agent": {
      "enabled": "Y",
      "phase": 1,
      "dependencies": []
    },
    "resource_allocator_agent": {
      "enabled": "Y",
      "phase": 2,
      "dependencies": ["sizing_agent"]
    },
    "data_quality_agent": {
      "enabled": "Y",
      "phase": 2,
      "dependencies": ["compliance_agent"]
    },
    "healing_agent": {
      "enabled": "N",
      "phase": 2,
      "dependencies": []
    },
    "platform_conversion_agent": {
      "enabled": "N",
      "phase": 3,
      "dependencies": ["sizing_agent", "resource_allocator_agent"]
    },
    "code_conversion_agent": {
      "enabled": "N",
      "phase": 3,
      "dependencies": ["platform_conversion_agent"]
    },
    "execution_agent": {
       "enabled": "Y",
       "phase": 4,
       "dependencies": []
  },
   "learning_agent": {
      "enabled": "Y",
      "phase": 5,
      "dependencies": []
    },
    "recommendation_agent": {
      "enabled": "Y",
      "phase": 6,
      "dependencies": ["all"],
      "_comment": "Runs last to aggregate all recommendations"
    }
  },

  "glue_config": {
    "glue_version": "4.0",
    "worker_type": "G.2X",
    "number_of_workers": 20,
    "timeout_minutes": 360,
    "max_retries": 2,
    "_comment": "These values may be overridden by smart_allocation if enabled",
    "spark_configs": {
      "spark.sql.adaptive.enabled": "true",
      "spark.sql.adaptive.coalescePartitions.enabled": "true",
      "spark.sql.adaptive.skewJoin.enabled": "true",
      "spark.sql.shuffle.partitions": "100",
      "spark.sql.broadcastTimeout": "600",
      "spark.dynamicAllocation.enabled": "true"
    }
  },

  "emr_config": {
    "release_label": "emr-6.15.0",
    "instance_type": "m5.2xlarge",
    "instance_count": 10,
    "use_spot": "Y",
    "spot_bid_percentage": 80,
    "applications": ["Spark", "Hadoop"],
    "spark_configs": {
      "spark.executor.memory": "12g",
      "spark.executor.cores": "4",
      "spark.sql.shuffle.partitions": "400",
      "spark.dynamicAllocation.enabled": "true"
    }
  },

  "eks_config": {
    "cluster_name": "enterprise-etl-eks",
    "namespace": "spark-jobs",
    "use_karpenter": "Y",
    "use_spot": "Y",
    "use_graviton": "Y",
    "executor_instances": 20,
    "executor_memory": "12g",
    "executor_cores": 4,
    "karpenter_provisioner": {
      "name": "spark-executors",
      "capacity_types": ["spot", "on-demand"],
      "architectures": ["amd64", "arm64"],
      "instance_families": ["m5", "m6i", "m6g", "r5", "r6i"]
    }
  },

  "auto_healing": {
    "enabled": "N",
    "correct_code": "Y",
    "auto_rerun": "Y",
    "max_retries": 3,
    "heal_memory_errors": "Y",
    "heal_shuffle_errors": "Y",
    "heal_timeout_errors": "Y",
    "heal_connection_errors": "Y",
    "heal_data_skew": "Y",
    "heal_partition_errors": "Y",
    "_comment": "Full auto-healing for complex multi-join pipeline"
  },

  "code_analysis": {
    "enabled": "Y",
    "check_anti_patterns": "Y",
    "check_join_optimizations": "Y",
    "check_window_functions": "Y",
    "check_aggregation_patterns": "Y",
    "recommend_aws_tools": "Y",
    "recommend_broadcast_joins": "Y",
    "recommend_caching": "Y"
  },

  "data_quality": {
    "enabled": "Y",
    "fail_on_critical": "Y",
    "pre_load_rules": [
    {
      "table": "life_insurance_base.life_policy",
      "rules": [
        {"type": "not_null", "column": "modal_premium", "severity": "warning"},
        {"type": "not_null", "column": "policy_number", "severity": "critical"},
        {"type": "completeness", "column": "product_line", "threshold": 0.95},
        {"type": "row_count_check", "min_rows": 1000000, "severity": "warning"}
      ]
    }
  ],
    "post_load_rules": [
    {
      "table": "life_insurance_master.enterprise_life_policy_master_v2",
      "rules": [
        {"type": "not_null", "column": "modal_premium", "severity": "warning"},
        {"type": "row_count_check", "min_rows": 100000, "severity": "critical"},
        {"type": "completeness", "column": "policy_number", "threshold": 0.95}
      ]
    }
  ],
  "natural_language_rules": [
  {
    "rule": "policy_number should not be null",
    "tables": ["life_insurance_base.life_policy"],
    "severity": "critical"
  },
  {
    "rule": "modal_premium should be positive",
    "tables": ["life_insurance_base.life_policy"],
    "severity": "warning"
  }
],


    "template_rules": [
      {
        "template": "null_check",
        "parameters": {"column": "policy_number"}
      },
      {
        "template": "completeness_check",
        "parameters": {"column": "policy_number"},
        "threshold": 0.99
      }
    ]
  },

  "compliance": {
    "enabled": "Y",
    "table_scans": [
           {
        "table": "life_insurance_base.life_policy",
        "columns": ["policy_number"],
        "pii_check": true,
        "masking_required": false
         }
    ],
    "check_sources": "Y",
    "check_targets": "Y",
    "frameworks": ["GDPR", "PCI_DSS", "SOX", "HIPAA"],
    "pii_columns": [
      "policy_number","date_of_birth","home_phone_number"
    ],
    "mask_pii": "N",
    "mask_strategy": "hash",
    "audit_data_access": "Y",
    "retention_days": 365
  },

  "learning": {
    "enabled": "Y",
    "store_history": "Y",
    "history_table": "etl_execution_history",
    "baseline_table": "etl_job_baselines",
    "detect_anomalies": "Y",
    "predict_failures": "Y",
    "update_baseline": "Y",
    "trend_window_days": 30,
    "_storage": "Local pipe-delimited files in data/agent_store/learning_agent/"
  },

  "recommendation": {
    "enabled": "Y",
    "aggregate_from_all_agents": "Y",
    "prioritize_by_impact": "Y",
    "generate_implementation_plan": "Y",
    "track_recommendation_status": "Y",
    "_storage": "Local pipe-delimited files in data/agent_store/recommendation_agent/"
  },

  "audit": {
    "enabled": "Y",
    "primary_storage": "local",
    "fallback_storage": "local",
    "dynamo_table": "etl_audit_log",
    "local_path": "data/agent_store/audit_logs",
    "format": "pipe_delimited",
    "s3_upload": "Y",
    "s3_audit_path": "s3://enterprise-etl-data/audit_logs/",
    "audit_on_start": "Y",
    "audit_on_read": "Y",
    "audit_on_transform": "Y",
    "audit_on_dq": "Y",
    "audit_on_compliance": "Y",
    "audit_on_write": "Y",
    "audit_on_complete": "Y",
    "audit_on_error": "Y",
    "audit_on_healing": "Y",
    "include_row_counts": "Y",
    "include_schema_info": "Y",
    "_comment": "Audit logs stored as pipe-delimited files locally, then uploaded to S3"
  },

  "source_tables": [
    {
      "database": "membership_datalake",
      "table": "mrd_mbrshp_household",
      "format": "parquet",
      "location": "s3://ace-da-membership-us-west-2-564021763094/Datalake_durga/mrd_mbrshp_household/",
      "partition_column": "",
      "auto_detect_size": "Y"
    },
    {
      "database": "membership_datalake",
      "table": "mrd_mbr_info",
      "format": "parquet",
      "location": "s3://ace-da-membership-us-west-2-564021763094/Datalake_durga/mrd_mbr_info/",
      "partition_column": "",
      "auto_detect_size": "Y"
    },

    {
      "_domain": "DIGITAL/CLICKSTREAM",
      "database": "membership_datalake",
      "table": "mrd_mbrshp_bill_plan",
      "format": "parquet",
      "location": "s3://ace-da-membership-us-west-2-564021763094/Base/mrd_mbrshp_bill_plan/",
      "partition_column": "",
      "auto_detect_size": "Y",
      "_note": "Very small table - may be used for broadcast"
    },

     {
      "_domain": "DIGITAL/CLICKSTREAM",
      "database": "membership_datalake",
      "table": "mrd_mbr_type",
      "format": "parquet",
      "location": "s3://ace-da-membership-us-west-2-564021763094/Base/mrd_mbr_type/",
      "partition_column": "insert_date",
      "auto_detect_size": "Y",
      "_note": "Very small table - may be used for broadcast"
    }


  ],

  "target_tables": [
    {
      "database": "membership_base",
      "table": "household_members_base",
      "format": "parquet",
      "location": "s3://ace-da-membership-us-west-2-564021763094/Base/household_members_base/",
      "partition_by": "insert_date",
      "write_mode": "overwrite_partitions",
      "enable_statistics": true
    }
  ],

  "schedule": {
    "enabled": "Y",
    "cron_expression": "0 5 * * *",
    "timezone": "America/New_York",
    "retry_on_failure": "Y",
    "max_retries": 2,
    "_comment": "Runs at 5 AM ET daily"
  }
}