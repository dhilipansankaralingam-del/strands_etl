{
  "job_name": "enterprise_sales_pipeline",
  "description": "Complex multi-source sales pipeline with full notifications and DQ",

  "source": {
    "type": "multi_source",
    "sources": [
      {
        "name": "transactions",
        "type": "glue_catalog",
        "database": "sales_db",
        "table": "transactions"
      },
      {
        "name": "customers",
        "type": "glue_catalog",
        "database": "crm_db",
        "table": "customers"
      },
      {
        "name": "products",
        "type": "s3",
        "path": "s3://master-data/products/",
        "format": "parquet"
      }
    ]
  },

  "target": {
    "type": "iceberg",
    "catalog": "glue_catalog",
    "database": "analytics_db",
    "table": "sales_facts",
    "mode": "merge",
    "merge_keys": ["transaction_id"],
    "partition_by": ["year", "month", "region"]
  },

  "platform": {
    "primary": "emr",
    "fallback": ["glue", "eks"],
    "auto_heal": true
  },

  "transformations": [
    {
      "type": "join",
      "left": "transactions",
      "right": "customers",
      "on": ["customer_id"],
      "how": "left"
    },
    {
      "type": "join",
      "left": "_result",
      "right": "products",
      "on": ["product_id"],
      "how": "left"
    },
    {
      "type": "filter",
      "condition": "transaction_status = 'COMPLETED' AND amount > 0"
    },
    {
      "type": "add_columns",
      "columns": {
        "year": "YEAR(transaction_date)",
        "month": "MONTH(transaction_date)",
        "region": "COALESCE(customer_region, 'UNKNOWN')",
        "revenue": "quantity * unit_price * (1 - discount_pct)"
      }
    },
    {
      "type": "aggregate",
      "group_by": ["year", "month", "region", "product_category"],
      "aggregations": {
        "total_revenue": "SUM(revenue)",
        "transaction_count": "COUNT(*)",
        "unique_customers": "COUNT(DISTINCT customer_id)"
      }
    }
  ],

  "data_quality": {
    "enabled": "Y",
    "fail_on_error": "N",
    "rules": [
      {
        "name": "no_null_transaction_id",
        "type": "not_null",
        "column": "transaction_id"
      },
      {
        "name": "valid_amount",
        "type": "range",
        "column": "amount",
        "min": 0,
        "max": 1000000
      },
      {
        "name": "valid_date",
        "type": "date_range",
        "column": "transaction_date",
        "min": "2020-01-01",
        "max": "2030-12-31"
      },
      {
        "name": "referential_integrity",
        "type": "sql",
        "query": "SELECT COUNT(*) FROM _result WHERE customer_id IS NOT NULL AND customer_name IS NULL",
        "expected": 0
      },
      {
        "name": "completeness_check",
        "type": "completeness",
        "threshold": 0.95
      }
    ]
  },

  "compliance": {
    "enabled": "Y",
    "frameworks": ["GDPR", "PCI-DSS"],
    "pii_columns": ["customer_email", "customer_phone", "credit_card_last4"],
    "mask_pii": "Y",
    "audit_access": "Y"
  },

  "notifications": {
    "enabled": "Y",

    "slack": {
      "enabled": "Y",
      "webhook_url": "${SLACK_WEBHOOK_URL}",
      "channel": "#data-platform-alerts",
      "bot_token": "xoxb-your-bot-token"
    },

    "teams": {
      "enabled": "Y",
      "webhook_url": "https://outlook.office.com/webhook/xxx-xxx-xxx/IncomingWebhook/yyy/zzz",
      "channel": "Data Platform"
    },

    "email": {
      "enabled": "Y",
      "sender": "data-platform@company.com",
      "recipients": [
        "data-engineering@company.com",
        "data-quality@company.com",
        "oncall@company.com"
      ],
      "ses_region": "us-east-1"
    },

    "preferences": {
      "on_start": "Y",
      "on_success": "Y",
      "on_failure": "Y",
      "on_warning": "Y",
      "on_dq_failure": "Y",
      "on_cost_alert": "Y",
      "on_recommendations": "Y",

      "dq_score_threshold": 0.85,
      "cost_alert_threshold_usd": 50.0,
      "duration_alert_minutes": 30,

      "mention_users_on_failure": [
        "oncall-lead@company.com"
      ]
    }
  },

  "scheduling": {
    "enabled": "Y",
    "cron": "0 6 * * *",
    "timezone": "America/New_York",
    "retry_on_failure": 3,
    "retry_delay_minutes": 15
  },

  "resources": {
    "glue": {
      "worker_type": "G.2X",
      "number_of_workers": 10,
      "timeout_minutes": 120
    },
    "emr": {
      "cluster_type": "transient",
      "master_instance_type": "m5.xlarge",
      "core_instance_type": "r5.2xlarge",
      "core_instance_count": 5,
      "use_spot": "Y",
      "spot_bid_percentage": 60
    },
    "eks": {
      "use_karpenter": "Y",
      "use_spot": "Y",
      "use_graviton": "Y",
      "node_pool": "spark-workloads"
    }
  },

  "audit": {
    "enabled": "Y",
    "store_lineage": "Y",
    "store_metrics": "Y",
    "store_recommendations": "Y",
    "retention_days": 90
  }
}
