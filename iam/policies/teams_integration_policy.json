{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "SecretsManagerTeamsWebhook",
            "Effect": "Allow",
            "Action": [
                "secretsmanager:GetSecretValue",
                "secretsmanager:DescribeSecret"
            ],
            "Resource": [
                "arn:aws:secretsmanager:*:*:secret:etl/teams/*",
                "arn:aws:secretsmanager:*:*:secret:etl/notifications/teams-*"
            ]
        },
        {
            "Sid": "KMSDecryptSecrets",
            "Effect": "Allow",
            "Action": [
                "kms:Decrypt",
                "kms:DescribeKey"
            ],
            "Resource": "arn:aws:kms:*:*:key/*",
            "Condition": {
                "StringEquals": {
                    "kms:ViaService": "secretsmanager.*.amazonaws.com"
                }
            }
        },
        {
            "Sid": "CloudWatchLogsForTeams",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/etl-teams-*"
        },
        {
            "Sid": "LambdaInvokeTeamsNotifier",
            "Effect": "Allow",
            "Action": [
                "lambda:InvokeFunction"
            ],
            "Resource": "arn:aws:lambda:*:*:function:etl-teams-notifier"
        }
    ]
}
