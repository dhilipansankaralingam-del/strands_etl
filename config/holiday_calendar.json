  "zscore_thresholds": {
    "_comment": "Adjusted Z-score thresholds when holiday context is detected.",
    "normal_day":           {"alert_zscore": 3.0, "critical_zscore": 5.0},
    "holiday_low_volume":   {"alert_zscore": 99.0, "critical_zscore": 99.0, "note": "Suppress all volume alerts on known low-volume holidays"},
    "post_holiday_surge":   {"alert_zscore": 6.0, "critical_zscore": 10.0, "note": "Raise threshold day after holiday — surge is expected"},
    "weekend":              {"alert_zscore": 4.0, "critical_zscore": 7.0},
    "month_end":            {"alert_zscore": 5.0, "critical_zscore": 8.0},
    "black_friday_cyber":   {"alert_zscore": 99.0, "critical_zscore": 99.0, "note": "Volume spikes are expected — do not alert"}
  },

  "club_overrides": {
    "_comment": "Per-club multiplier adjustments for clubs in states with additional state/regional holidays.",
    "CA": {
      "cesar_chavez_day": {"month": 3, "day": 31, "multiplier": 0.70, "note": "California state holiday"}
    },
    "TX": {
      "san_jacinto_day": {"month": 4, "day": 21, "multiplier": 0.80}
    },
    "HI": {
      "statehood_day": {"month": 8, "week": 3, "weekday": "Friday", "multiplier": 0.40}
    }
  },

  "usage_instructions": {
    "how_agent_uses_this": [
      "1. Agent reads failure_timestamp from the audit record.",
      "2. Looks up the date in explicit_dates_{year} map.",
      "3. If found: applies volume_multiplier to expected baseline.",
      "4. If today's count >= baseline * multiplier * 0.5 → FALSE_POSITIVE.",
      "5. Checks if yesterday was a holiday → applies surge_next for post-holiday check.",
      "6. For per-club checks: also applies club_overrides for the club's state prefix.",
      "7. All threshold adjustments are logged in ai_explanation for auditability."
    ]
  }
}
